# Môi trường chạy (development / production)
NODE_ENV=development

# Cổng chạy ứng dụng
PORT=5000

# Chuỗi kết nối MongoDB
MONGODB_URL=mongodb://localhost:27017/e-warranty

# URL của Frontend (dùng cho CORS)
FRONTEND_URL=http://localhost:5173

# Khóa bí mật JWT (BẮT BUỘC trong môi trường production)
JWT_SECRET=your_super_secret_jwt_key_here

# Thời gian hết hạn của JWT
JWT_EXPIRES_IN=1d

# Pinata JWT dùng để upload lên IPFS (BẮT BUỘC để upload ảnh và metadata)
PINATA_JWT=your_pinata_jwt_here

# Chế độ Demo (true/false)
DEMO_MODE=false
