{
  "name": "ie213",
  "version": "1.0.0",
  "description": "Hệ thống Cấp phát và Quản lý Phiếu bảo hành Điện tử bằng NFT",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "install:all": "npm install",
    "backend": "npm run dev --workspace backend",
    "frontend": "npm run start --workspace frontend",
    "dev": "concurrently -k \"npm run backend\" \"npm run frontend\"",
    "build": "npm run build --workspace frontend",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "npm run test --workspace backend",
    "test:frontend": "npm run test --workspace frontend -- --watchAll=false"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "keywords": [
    "nodejs",
    "express",
    "react",
    "fullstack"
  ],
  "author": "",
  "license": "MIT"
}
